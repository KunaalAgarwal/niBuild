{
  "name": "niBuild",
  "version": "1.0.0",
  "description": "Front end for the CWL neuro analysis workflow app.",
  "type": "module",
  "homepage": "https://kunaalagarwal.github.io/niBuild",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/downloadStandardTemplates.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "templates:download": "node scripts/downloadStandardTemplates.mjs",
    "lint": "eslint src/ scripts/",
    "lint:fix": "eslint src/ scripts/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"scripts/**/*.mjs\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "keywords": [],
  "author": "Kunaal Agarwal and Javier Rasero",
  "license": "MIT",
  "dependencies": {
    "bootstrap": "^5.3.3",
    "file-saver": "^2.0.5",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.9",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.4.6",
    "react-resizable-panels": "^4.11.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vite": "^5.4.9"
  }
}
